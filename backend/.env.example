# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Tatum.io Configuration
TATUM_API_KEY=your_tatum_api_key
TATUM_API_URL=https://api.tatum.io/v3

# Cashfree Configuration
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_API_URL=https://api.cashfree.com/pg

# HyperVerge KYC Configuration
HYPERVERGE_API_KEY=your_hyperverge_api_key
HYPERVERGE_API_URL=https://api.hyperverge.co/v2

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_chars

# Redis Configuration (Optional, for caching)
REDIS_URL=redis://localhost:6379

# Price Feed Configuration
PRICE_FEED_URL=https://api.coingecko.com/api/v3

# Environment
NODE_ENV=development
